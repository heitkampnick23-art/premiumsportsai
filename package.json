{
  "name": "premiumsportsai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static --project-name=premiumsportsai --commit-dirty=true",
    "pages:preview": "npm run pages:build && wrangler pages dev .vercel/output/static",
    "cron:deploy": "wrangler deploy --config wrangler.cron.toml",
    "db:migrate:local": "wrangler d1 migrations apply premiumsportsai --local",
    "db:migrate:remote": "wrangler d1 migrations apply premiumsportsai --remote"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "next": "15.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^17.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "wrangler": "^3.86.0"
  }
}
